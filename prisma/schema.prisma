// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AgendaAction {
  Poll
  Transaction
  Giveaway
  Q_A
  Custom
  Quiz 
}

enum StreamSessionType {
  Livestream
  Meeting
  Podcast
}

enum CallType {
  Video
  Audio
}

enum StreamFundingType {
  Live
  Prepaid
  Conditional
}

model Tenant {
  id                String        @id @default(cuid())
  creatorWallet     String        @unique
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Customization fields
  theme             String?       // Theme identifier or name
  primaryColor      String?       // Hex color code
  secondaryColor    String?       // Hex color code
  logo              String? 
  name              String?       // Tenant name
  templateId        String?       // Reference to template if you store templates separately
  rpcEndpoint       String?       // Custom RPC endpoint URL
  networkCluster    String?       // e.g., "mainnet-beta", "devnet", "testnet"
  defaultStreamType StreamSessionType  @default(Meeting)
  defaultFundingType StreamFundingType @default(Live)
  enabledStreamTypes EnabledStreamTypes?

  // Tenant level authorized domains
  authorizedDomains AuthorizedDomain[]
  
  // Tenant relationships
  users             User[]
  streams           Stream[]
  transactions      Transaction[]
  agendas           Agenda[]
  participants      Participant[]
  apiTokens         ApiToken[]    // For managing multiple API tokens per tenant
}

// API token model for SDK authentication
model ApiToken {
  id          String    @id @default(cuid())
  key         String    @unique  // Public API key for identification
  secret      String    @unique  // Secret key (hashed) for authentication
  name        String    // A descriptive name for the token
  tenantId    String
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  isActive    Boolean   @default(true)
  
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AuthorizedDomain {
  id          String    @id @default(cuid())
  domain      String    // e.g., "thestreamlink.com"
  tenantId    String
  createdAt   DateTime  @default(now())
  
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([domain, tenantId]) // Each domain can only be added once per tenant
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?
  emailVerified DateTime?
  image         String?
  walletAddress String
  points        Int?
  tenantId      String        // Which tenant the user belongs to
  
  accounts      Account[]
  streams       Stream[]
  transaction   Transaction[]
  
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([walletAddress, tenantId]) // Wallet addresses must be unique within a tenant
  @@index([tenantId, email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
}

model Stream {
  id           String        @id @default(cuid())
  name         String
  userId       String
  title        String?
  callType     CallType
  streamSessionType   StreamSessionType
  scheduledFor DateTime?
  creatorWallet String
  hasHost      Boolean       @default(false)
  recording    Boolean       @default(false)
  recordId     String?
  recordLink   String?
  tenantId     String
  isLive       Boolean       @default(false)
  startedAt    DateTime?
  endedAt      DateTime?
  isPublic     Boolean       @default(true) // true = open to everyone, false = requires permission
  fundingType  StreamFundingType  @default(Live)
  
  agenda       Agenda[]
  participants Participant[]
  
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([name, tenantId]) // Names must be unique within a tenant
  @@index([tenantId, userId])
}

model EnabledStreamTypes {
  id             String           @id @default(cuid())
  tenantId       String           @unique
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enableStream   Boolean          @default(true)
  enableMeeting  Boolean          @default(true)
  enablePodcast  Boolean          @default(false)
}

model Transaction {
  id         Int      @id @default(autoincrement())
  userId     String
  signature  String
  createdAt  DateTime @default(now())
  tenantId   String
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId, userId])
}

model Agenda {
  id           String         @id @default(cuid())
  streamId     String
  timeStamp    Int
  action       AgendaAction
  title        String?        // Title for any agenda item type
  description  String?        // Optional description for any agenda item  
  tenantId     String
  
  // Relationships
  stream       Stream         @relation(fields: [streamId], references: [id])
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Specific content relationships based on action type
  pollContent             PollContent?            // For Poll actions
  quizContent             QuizContent?            // For Quiz actions
  assetTransferContent    AssetTransferContent?   // For Transaction and Giveaway actions
  qaContent               QAContent?              // For Q_A actions
  customContent           CustomContent?          // For Custom actions
  
  // Participant scores/responses
  participantResponses ParticipantResponse[]
  
  @@index([tenantId, streamId])
}

// Poll-specific content
model PollContent {
  id          String     @id @default(cuid())
  agendaId    String     @unique
  options     String[]   // Poll options instead of using wallets
  totalVotes  Int        @default(0)
  
  // Relationship
  agenda      Agenda     @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  votes       PollVote[]
}

// Quiz-specific content
model QuizContent {
  id          String       @id @default(cuid())
  agendaId    String       @unique
  questions   QuizQuestion[] // One-to-many relationship with questions
  
  // Relationship
  agenda      Agenda       @relation(fields: [agendaId], references: [id], onDelete: Cascade)
}

// Quiz Questions
model QuizQuestion {
  id            String     @id @default(cuid())
  quizContentId String
  questionText  String
  options       String[]   // Available options (for multiple choice)
  correctAnswer String     // The correct answer or option
  isMultiChoice Boolean    @default(true)
  points        Int        @default(1) // Points awarded for correct answer
  
  // Relationship
  quizContent   QuizContent @relation(fields: [quizContentId], references: [id], onDelete: Cascade)
  responses     QuizResponse[]
  
  @@index([quizContentId])
}

// Asset transfer content (for both Transaction and Giveaway actions)
model AssetTransferContent {
  id          String     @id @default(cuid())
  agendaId    String     @unique
  assetType   String     // "NFT" or "Token" or other asset types
  transferType String     // "Transaction" or "Giveaway" - preserves the original action type intent
  
  // Relationship
  agenda      Agenda     @relation(fields: [agendaId], references: [id], onDelete: Cascade)
}

// Q&A-specific content
model QAContent {
  id          String     @id @default(cuid())
  agendaId    String     @unique
  topic       String?    // Topic of the Q&A session
  
  // Relationship
  agenda      Agenda     @relation(fields: [agendaId], references: [id], onDelete: Cascade)
}

// Custom-specific content
model CustomContent {
  id          String     @id @default(cuid())
  agendaId    String     @unique
  customData  Json?      // Flexible field for custom agenda items
  
  // Relationship
  agenda      Agenda     @relation(fields: [agendaId], references: [id], onDelete: Cascade)
}

// Tracking poll votes
model PollVote {
  id              String      @id @default(cuid())
  pollContentId   String      // Reference to the PollContent
  pollContent     PollContent @relation(fields: [pollContentId], references: [id], onDelete: Cascade)
  selectedOption  String      // The option that was voted for
  participant     Participant @relation(fields: [participantId], references: [id])
  participantId   String

  @@unique([pollContentId, participantId]) // One vote per participant per poll
  @@index([pollContentId, selectedOption]) // For faster counting
}

// Tracking quiz responses
model QuizResponse {
  id              String        @id @default(cuid())
  questionId      String
  question        QuizQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  participantId   String
  participant     Participant   @relation(fields: [participantId], references: [id])
  answer          String        // The participant's answer
  isCorrect       Boolean       // Whether the answer is correct
  pointsEarned    Int           // Points earned for this response
  
  @@unique([questionId, participantId]) // One response per participant per question
  @@index([questionId, isCorrect]) // For faster stats calculation
}

// Record of participant responses to any agenda item
model ParticipantResponse {
  id              String      @id @default(cuid())
  agendaId        String
  agenda          Agenda      @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  participantId   String
  participant     Participant @relation(fields: [participantId], references: [id])
  responseType    String      // e.g., "vote", "quiz_answer", "question", etc.
  timestamp       DateTime    @default(now())
  
  @@index([agendaId, participantId])
}

// Updated Participant model with score tracking
model Participant {
  id            String     @id @default(cuid())
  streamId      String
  userName      String
  walletAddress String
  userType      String
  joinedAt      DateTime   @default(now())
  leftAt        DateTime?
  tenantId      String
  
  // Score tracking
  totalPoints   Int        @default(0)  // Accumulated points from quizzes etc.
  
  // Relationships
  stream        Stream     @relation(fields: [streamId], references: [id], onDelete: Cascade)
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pollVotes     PollVote[]
  quizResponses QuizResponse[]
  responses     ParticipantResponse[]
  
  @@index([tenantId, streamId])
}

