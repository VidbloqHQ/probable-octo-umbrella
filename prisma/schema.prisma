generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                  String               @id @default(cuid())
  creatorWallet       String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  theme               String?
  primaryColor        String?
  secondaryColor      String?
  accentColor         String?
  textPrimaryColor    String?
  textSecondaryColor  String?
  logo                String?
  shortLogo           String?
  name                String?
  templateId          String?
  rpcEndpoint         String?
  networkCluster      String?
  defaultStreamType   StreamSessionType    @default(Meeting)
  defaultFundingType  StreamFundingType    @default(Live)
  agendas             Agenda[]
  apiTokens           ApiToken[]
  authorizedDomains   AuthorizedDomain[]
  enabledStreamTypes  EnabledStreamTypes?
  participants        Participant[]
  programStreams      ProgramStream[]
  streams             Stream[]
  streamDistributions StreamDistribution[]
  streamDonations     StreamDonation[]
  transactions        Transaction[]
  users               User[]
}

model ApiToken {
  id         String    @id @default(cuid())
  key        String    @unique
  secret     String
  name       String
  tenantId   String
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  lastUsedAt DateTime?
  isActive   Boolean   @default(true)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([key, tenantId])
  @@index([tenantId])
}

model AuthorizedDomain {
  id        String   @id @default(cuid())
  domain    String
  tenantId  String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([domain, tenantId])
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?
  emailVerified       DateTime?
  image               String?
  walletAddress       String
  points              Int?
  tenantId            String
  accounts            Account[]
  solanaStreams       ProgramStream[]
  streams             Stream[]
  streamDistributions StreamDistribution[]
  streamDonations     StreamDonation[]
  transaction         Transaction[]
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([walletAddress, tenantId])
  @@index([tenantId, email])
  @@index([walletAddress, tenantId])
  @@index([walletAddress, tenantId], map: "idx_user_wallet_tenant")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "idx_account_userid")
}

model Stream {
  id                  String            @id @default(cuid())
  name                String
  userId              String
  title               String?
  callType            CallType
  streamSessionType   StreamSessionType
  scheduledFor        DateTime?
  creatorWallet       String
  hasHost             Boolean           @default(false)
  recording           Boolean           @default(false)
  recordId            String?
  recordLink          String?
  tenantId            String
  isLive              Boolean           @default(false)
  createdAt           DateTime?
  startedAt           DateTime?
  endedAt             DateTime?
  isPublic            Boolean           @default(true)
  fundingType         StreamFundingType @default(Live)
  version             Int               @default(1)
  recordingType       String?
  recordingUrl        String?
  recordingOutputType String?
  lastRecordingUrl    String?
  youtubeEgressId     String?
  agenda              Agenda[]
  participants        Participant[]
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]

  @@unique([name, tenantId])
  @@index([tenantId, userId])
  @@index([name, tenantId])
  @@index([name, tenantId], map: "idx_stream_name_tenant")
  @@index([name, tenantId, id], map: "idx_stream_name_tenant_id")
}

model EnabledStreamTypes {
  id            String  @id @default(cuid())
  tenantId      String  @unique
  enableStream  Boolean @default(true)
  enableMeeting Boolean @default(true)
  enablePodcast Boolean @default(false)
  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Transaction {
  id               Int                 @id @default(autoincrement())
  userId           String
  signature        String
  createdAt        DateTime            @default(now())
  tenantId         String
  transactionType  String?
  solanaStreamId   String?
  donationId       String?
  distributionId   String?
  amount           String?
  tokenName        String?
  narration        String?
  streamId         String?
  senderAddress    String?
  recipientAddress String?
  recipients       Json?
  status           String?             @default("pending")
  distribution     StreamDistribution? @relation(fields: [distributionId], references: [id])
  donation         StreamDonation?     @relation(fields: [donationId], references: [id])
  programStream    ProgramStream?      @relation(fields: [solanaStreamId], references: [id])
  stream           Stream?             @relation(fields: [streamId], references: [id])
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([transactionType])
  @@index([streamId])
  @@index([status])
  @@index([createdAt])
  @@index([distributionId], map: "idx_transaction_distributionid")
  @@index([donationId], map: "idx_transaction_donationid")
  @@index([solanaStreamId], map: "idx_transaction_solanastreamid")
}

model Agenda {
  id                   String                @id @default(cuid())
  streamId             String
  timeStamp            Int
  action               AgendaAction
  title                String?
  description          String?
  tenantId             String
  duration             Int?
  isCompleted          Boolean               @default(false)
  stream               Stream                @relation(fields: [streamId], references: [id])
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customContent        CustomContent?
  participantResponses ParticipantResponse[]
  pollContent          PollContent?
  qaContent            QAContent?
  quizContent          QuizContent?

  @@index([tenantId, streamId])
  @@index([id, tenantId], map: "idx_agenda_id_tenant")
  @@index([streamId, tenantId], map: "idx_agenda_stream_tenant")
  @@index([streamId, timeStamp], map: "idx_agenda_stream_timestamp")
}

model PollContent {
  id         String     @id @default(cuid())
  agendaId   String     @unique
  options    String[]
  totalVotes Int        @default(0)
  agenda     Agenda     @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  votes      PollVote[]
}

model QuizContent {
  id        String         @id @default(cuid())
  agendaId  String         @unique
  agenda    Agenda         @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
}

model QuizQuestion {
  id            String         @id @default(cuid())
  quizContentId String
  questionText  String
  options       String[]
  correctAnswer String
  isMultiChoice Boolean        @default(true)
  points        Int            @default(1)
  quizContent   QuizContent    @relation(fields: [quizContentId], references: [id], onDelete: Cascade)
  responses     QuizResponse[]

  @@index([quizContentId])
  @@index([quizContentId], map: "idx_quiz_question_content")
}

model QAContent {
  id       String  @id @default(cuid())
  agendaId String  @unique
  topic    String?
  agenda   Agenda  @relation(fields: [agendaId], references: [id], onDelete: Cascade)
}

model CustomContent {
  id         String @id @default(cuid())
  agendaId   String @unique
  customData Json?
  agenda     Agenda @relation(fields: [agendaId], references: [id], onDelete: Cascade)
}

model PollVote {
  id             String      @id @default(cuid())
  pollContentId  String
  selectedOption String
  participantId  String
  participant    Participant @relation(fields: [participantId], references: [id])
  pollContent    PollContent @relation(fields: [pollContentId], references: [id], onDelete: Cascade)

  @@unique([pollContentId, participantId])
  @@index([pollContentId, selectedOption])
}

model QuizResponse {
  id            String       @id @default(cuid())
  questionId    String
  participantId String
  answer        String
  isCorrect     Boolean
  pointsEarned  Int
  participant   Participant  @relation(fields: [participantId], references: [id])
  question      QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, participantId])
  @@index([questionId, isCorrect])
}

model ParticipantResponse {
  id            String      @id @default(cuid())
  agendaId      String
  participantId String
  responseType  String
  timestamp     DateTime    @default(now())
  agenda        Agenda      @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  participant   Participant @relation(fields: [participantId], references: [id])

  @@index([agendaId, participantId])
}

model Participant {
  id            String                @id @default(cuid())
  streamId      String
  userName      String
  walletAddress String
  userType      String
  avatarUrl     String?
  joinedAt      DateTime              @default(now())
  leftAt        DateTime?
  tenantId      String
  totalPoints   Int                   @default(0)
  version       Int                   @default(1)
  stream        Stream                @relation(fields: [streamId], references: [id], onDelete: Cascade)
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  responses     ParticipantResponse[]
  pollVotes     PollVote[]
  quizResponses QuizResponse[]

  @@unique([walletAddress, streamId, tenantId])
  @@index([tenantId, streamId])
  @@index([walletAddress, streamId, tenantId])
  @@index([streamId, walletAddress], map: "idx_participant_stream_wallet")
  @@index([streamId, tenantId], map: "idx_participants_stream_tenant")
  @@index([walletAddress, streamId], map: "idx_participants_wallet_stream")
}

model ProgramStream {
  id                           String               @id @default(cuid())
  name                         String
  streamType                   StreamFundingType
  streamPDA                    String
  streamATA                    String
  mintAddress                  String
  hostWallet                   String
  status                       ProgramStreamStatus  @default(Initialized)
  isInitialized                Boolean              @default(false)
  totalDeposited               BigInt               @default(0)
  totalDistributed             BigInt               @default(0)
  endTime                      DateTime?
  createdAt                    DateTime             @default(now())
  startedAt                    DateTime?
  endedAt                      DateTime?
  updatedAt                    DateTime             @updatedAt
  transactionSignature         String?
  startTransactionSignature    String?
  completeTransactionSignature String?
  updateTransactionSignature   String?
  tenantId                     String
  userId                       String
  tenant                       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  distributions                StreamDistribution[]
  donations                    StreamDonation[]
  transactions                 Transaction[]

  @@unique([name, hostWallet, tenantId])
  @@index([tenantId, userId])
  @@index([status])
}

model StreamDonation {
  id                         String        @id @default(cuid())
  amount                     String
  donorWallet                String
  donorPDA                   String
  status                     String        @default("pending")
  transactionSignature       String?
  createdAt                  DateTime      @default(now())
  confirmedAt                DateTime?
  refundPending              Boolean       @default(false)
  refundAmount               String?
  refundConfirmed            Boolean       @default(false)
  refundedAt                 DateTime?
  refundInitiator            String?
  refundTransactionSignature String?
  streamId                   String
  tenantId                   String
  userId                     String
  stream                     ProgramStream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  tenant                     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions               Transaction[]

  @@index([streamId])
  @@index([tenantId, userId])
  @@index([donorWallet])
}

model StreamDistribution {
  id                   String        @id @default(cuid())
  amount               String
  recipientWallet      String
  status               String        @default("pending")
  transactionSignature String?
  createdAt            DateTime      @default(now())
  confirmedAt          DateTime?
  streamId             String
  tenantId             String
  userId               String
  stream               ProgramStream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions         Transaction[]

  @@index([streamId])
  @@index([tenantId, userId])
  @@index([recipientWallet])
}

model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  response  Json
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([key])
  @@index([expiresAt])
}

enum AgendaAction {
  Poll
  Q_A
  Custom
  Quiz
}

enum StreamSessionType {
  Livestream
  Meeting
  Podcast
}

enum CallType {
  Video
  Audio
}

enum StreamFundingType {
  Live
  Prepaid
  Conditional
}

enum ProgramStreamStatus {
  Initialized
  Active
  Completed
  Cancelled
}
